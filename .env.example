# =====================================================
# DinnerDrop - Required Environment Variables
# Copy this file to .env.local and fill in your values
# =====================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Anthropic (meal planning AI) ---
ANTHROPIC_API_KEY=your_anthropic_key

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# --- Resend (email delivery - sign up at resend.com) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=DinnerDrop <info@dinnerdrop.app>

# --- Cron security (generate: openssl rand -hex 16) ---
CRON_SECRET=your_random_32_char_string

# --- App URL (used by email cron to call internal APIs) ---
# Local: http://localhost:3000 | Production: https://dinnerdrop.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Instacart (apply at developer.instacart.com) ---
INSTACART_API_KEY=your_instacart_key

# --- Kroger (apply at developer.kroger.com) ---
KROGER_CLIENT_ID=your_kroger_client_id
KROGER_CLIENT_SECRET=your_kroger_client_secret

# --- Unsplash (sign up at unsplash.com/developers) ---
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# --- Admin setup (internal use only) ---
SETUP_SECRET=your_setup_secret
INSTACART_API_ENV=sandbox

# --- Reddit Pixel (optional — set this to enable Reddit Ads conversion tracking) ---
# Find at: ads.reddit.com → Events Manager → Conversion Pixel
# Leave unset to disable Reddit Pixel firing.
NEXT_PUBLIC_REDDIT_PIXEL_ID=
